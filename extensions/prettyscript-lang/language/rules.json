{
    "syntax": {
        "keywords": [
            "use",
            "import",
            "from",
            "if",
            "else",
            "for",
            "while",
            "return",
            "break",
            "continue",
            "switch",
            "case",
            "default",
            "try",
            "catch",
            "finally",
            "throw",
            "class",
            "extends",
            "fn",
            "const",
            "let",
            "var",
            "include"
        ],
        "string": "\".*?\"",
        "comment": "//.*$",
        "constants": ["async", "await", "__filename", "__version", "__package"],
        "booleans": ["true", "false", "NaN"],
        "isUppercaseConstant": true,
        "numbers": "\\b(?:0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+(?:\\.\\d+)?)\\b",
        "camelCaseAsClassname": false,
        "uppercaseAsConstant": true,
        "defineFunctionKeyword": "fn",
        "functionCalls": "\\b\\w+(?=\\()",
        "defineClassKeyword": "class",
        "renderColors": true,
        "types": ["int", "string", "bool", "object", "array", "HTML", "any"],
        "custom": [
            {
                "regex": "@[A-Za-zА-Яа-яЁё_]+",
                "type": ["keyword"]
            },
            {
                "regex": "{[A-Za-zА-Яа-яЁё0-9_]+}",
                "type": ["constant.language"]
            }
        ]
    },
    "autocomplete": {
        "auto": true,
        "keywords":[
            {
                "prefix": "fn",
                "body": [
                    "fn ${0:foo}() {",
                    "\t${1}",
                    "}"
                ],
                "description": "Function definition"
            },
            {
                "prefix": "async",
                "body": [
                    "async ${0:foo}() {",
                    "\t${1}",
                    "}"
                ],
                "description": "Async function definition"
            }
        ]
    }
}